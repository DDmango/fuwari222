---
import Pagination from "../components/control/Pagination.astro";
import PostPage from "../components/PostPage.astro";
import { PAGE_SIZE } from "../constants/constants";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";

const allBlogPosts = await getCollection("posts", ({ data }) => {
	return !data.draft && (data.tags && data.tags.includes("Exness"));
});

const sorted = allBlogPosts.sort((a, b) => {
	const dateA = new Date(a.data.published);
	const dateB = new Date(b.data.published);
	return dateA > dateB ? -1 : 1;
});

// Add next/prev links
for (let i = 1; i < sorted.length; i++) {
	sorted[i].data.nextSlug = sorted[i - 1].slug;
	sorted[i].data.nextTitle = sorted[i - 1].data.title;
}
for (let i = 0; i < sorted.length - 1; i++) {
	sorted[i].data.prevSlug = sorted[i + 1].slug;
	sorted[i].data.prevTitle = sorted[i + 1].data.title;
}

const page = {
	data: sorted,
	currentPage: 1,
	lastPage: 1,
	url: {
		prev: undefined,
		next: undefined
	}
};

const len = page.data.length;
---

<MainGridLayout title="加密货币" description="加密货币专栏 - 区块链技术、数字货币分析与工具教程">
    <div class="space-y-6">
        {/* 页面标题 */}
        <div class="card-base p-6 rounded-[var(--radius-large)]">
            <h1 class="text-3xl font-bold mb-2">加密货币</h1>
            <p class="text-gray-500 dark:text-gray-400">区块链技术、数字货币分析与工具教程</p>
        </div>

        <PostPage page={page}></PostPage>
        <Pagination class="mx-auto onload-animation" page={page} baseUrl="/crypto/" style={`animation-delay: calc(var(--content-delay) + ${(len)*50}ms)`}></Pagination>
    </div>
</MainGridLayout>