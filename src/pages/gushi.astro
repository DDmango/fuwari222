---
import MainGridLayout from "../layouts/MainGridLayout.astro";

const API_KEY = '69e07e9fbf48a8.28155838';

function formatCode(code) {
    code = code.trim().toUpperCase();
    if (code.includes('.')) return code;
    if (/^6\d{5}$/.test(code)) return code + '.SS';
    if (/^0\d{5}$/.test(code) || /^3\d{5}$/.test(code)) return code + '.SZ';
    if (/^[A-Z]{1,5}$/.test(code)) return code + '.US';
    return code;
}

async function fetchStockData(code) {
    const url = `https://eodhd.com/api/eod/${code}?api_token=${API_KEY}&fmt=json`;
    
    try {
        const response = await fetch(url);
        if (!response.ok) return null;
        
        const data = await response.json();
        if (!Array.isArray(data) || data.length === 0) return null;
        
        return data.map(item => [
            item.date,
            typeof item.open === 'number' ? item.open.toFixed(2) : item.open,
            typeof item.close === 'number' ? item.close.toFixed(2) : item.close,
            typeof item.low === 'number' ? item.low.toFixed(2) : item.low,
            typeof item.high === 'number' ? item.high.toFixed(2) : item.high
        ]);
    } catch {
        return null;
    }
}

function generateMockData(count = 60) {
    const data = [];
    let price = 1500;
    const now = new Date();
    
    for (let i = count; i >= 0; i--) {
        const date = new Date(now);
        date.setDate(date.getDate() - i);
        const dateStr = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
        
        const volatility = (Math.random() - 0.5) * 100;
        const open = price + volatility;
        const close = open + (Math.random() - 0.5) * 80;
        const high = Math.max(open, close) + Math.random() * 30;
        const low = Math.min(open, close) - Math.random() * 30;
        
        data.push([dateStr, open.toFixed(2), close.toFixed(2), low.toFixed(2), high.toFixed(2)]);
        price = close;
    }
    return data;
}

const defaultCode = '600519.SS';
const serverData = await fetchStockData(defaultCode) || generateMockData();
const isRealData = serverData !== null && serverData.length > 0;
const lastData = serverData[serverData.length - 1];
---

<MainGridLayout title="股市图表" description="股票K线图分析">
    <div class="space-y-6">
        <div class="card-base p-6 rounded-[var(--radius-large)]">
            <h1 class="text-3xl font-bold mb-2">股市图表</h1>
            <p class="text-gray-500 dark:text-gray-400">实时查看股票K线图</p>
        </div>

        <div class="card-base p-6 rounded-[var(--radius-large)]">
            <div class="flex flex-wrap gap-4 mb-6">
                <div class="flex-1 min-w-[200px]">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">股票代码</label>
                    <input 
                        id="stock-code" 
                        type="text" 
                        value="600519"
                        placeholder="输入股票代码，如: 600519"
                        class="w-full px-4 py-2 rounded-lg border bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100"
                    />
                </div>
                <div class="flex-1 min-w-[200px] pt-6">
                    <button 
                        id="search-btn" 
                        class="w-full px-4 py-2 rounded-lg bg-blue-500 text-white hover:bg-blue-600"
                    >
                        查询K线图
                    </button>
                </div>
            </div>

            <div id="status" class="mb-4 text-lg font-medium">
                {defaultCode} - {isRealData ? `显示实时数据 (${serverData.length}条)` : '获取真实数据失败，显示模拟数据'}
            </div>

            <canvas id="chart-canvas" class="w-full h-[400px] bg-gray-100 dark:bg-gray-800 rounded-lg"></canvas>

            <div class="grid grid-cols-4 gap-4 mt-6">
                <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
                    <div class="text-sm text-gray-500 dark:text-gray-400">开盘价</div>
                    <div id="open-price" class="text-xl font-bold">¥{lastData[1]}</div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
                    <div class="text-sm text-gray-500 dark:text-gray-400">收盘价</div>
                    <div id="close-price" class="text-xl font-bold">¥{lastData[2]}</div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
                    <div class="text-sm text-gray-500 dark:text-gray-400">最高价</div>
                    <div id="high-price" class="text-xl font-bold text-red-500">¥{lastData[4]}</div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
                    <div class="text-sm text-gray-500 dark:text-gray-400">最低价</div>
                    <div id="low-price" class="text-xl font-bold text-green-500">¥{lastData[3]}</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const serverData = JSON.parse(decodeURIComponent('<%= encodeURIComponent(JSON.stringify(serverData)) %>'));
        const defaultCode = '<%= defaultCode %>';

        function formatCode(code) {
            code = code.trim().toUpperCase();
            if (code.includes('.')) return code;
            if (/^6\d{5}$/.test(code)) return code + '.SS';
            if (/^0\d{5}$/.test(code) || /^3\d{5}$/.test(code)) return code + '.SZ';
            if (/^[A-Z]{1,5}$/.test(code)) return code + '.US';
            return code;
        }

        function generateMockData(count = 60) {
            const data = [];
            let price = 1500;
            const now = new Date();
            
            for (let i = count; i >= 0; i--) {
                const date = new Date(now);
                date.setDate(date.getDate() - i);
                const dateStr = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
                
                const volatility = (Math.random() - 0.5) * 100;
                const open = price + volatility;
                const close = open + (Math.random() - 0.5) * 80;
                const high = Math.max(open, close) + Math.random() * 30;
                const low = Math.min(open, close) - Math.random() * 30;
                
                data.push([dateStr, open.toFixed(2), close.toFixed(2), low.toFixed(2), high.toFixed(2)]);
                price = close;
            }
            return data;
        }

        async function fetchData(code) {
            const apiKey = '69e07e9fbf48a8.28155838';
            const proxies = [
                `https://cors-anywhere.herokuapp.com/https://eodhd.com/api/eod/${code}?api_token=${apiKey}&fmt=json`,
                `https://corsproxy.io/?${encodeURIComponent(`https://eodhd.com/api/eod/${code}?api_token=${apiKey}&fmt=json`)}`,
                `https://api.allorigins.win/raw?url=${encodeURIComponent(`https://eodhd.com/api/eod/${code}?api_token=${apiKey}&fmt=json`)}`
            ];
            
            for (let i = 0; i < proxies.length; i++) {
                try {
                    const controller = new AbortController();
                    const timeout = setTimeout(() => controller.abort(), 10000);
                    
                    const response = await fetch(proxies[i], { signal: controller.signal });
                    clearTimeout(timeout);
                    
                    if (!response.ok) continue;
                    
                    const data = await response.json();
                    if (!Array.isArray(data) || data.length === 0) continue;
                    
                    return data.map(item => [
                        item.date,
                        typeof item.open === 'number' ? item.open.toFixed(2) : item.open,
                        typeof item.close === 'number' ? item.close.toFixed(2) : item.close,
                        typeof item.low === 'number' ? item.low.toFixed(2) : item.low,
                        typeof item.high === 'number' ? item.high.toFixed(2) : item.high
                    ]);
                } catch {
                    continue;
                }
            }
            return null;
        }

        function renderChart(data) {
            const canvas = document.getElementById('chart-canvas');
            if (!canvas) return;
            
            const ctx = canvas.getContext('2d');
            const rect = canvas.getBoundingClientRect();
            const dpr = window.devicePixelRatio || 1;
            
            canvas.width = rect.width * dpr;
            canvas.height = 400 * dpr;
            ctx.scale(dpr, dpr);
            
            const width = rect.width;
            const height = 400;
            const padding = 40;
            
            const isDark = document.documentElement.classList.contains('dark');
            const bgColor = isDark ? '#1f2937' : '#f3f4f6';
            const gridColor = isDark ? '#374151' : '#ddd';
            const textColor = isDark ? '#9ca3af' : '#666';
            
            ctx.fillStyle = bgColor;
            ctx.fillRect(0, 0, width, height);
            
            ctx.strokeStyle = gridColor;
            ctx.lineWidth = 1;
            for (let i = 0; i <= 5; i++) {
                const y = padding + (height - padding * 2) * i / 5;
                ctx.beginPath();
                ctx.moveTo(padding, y);
                ctx.lineTo(width - padding, y);
                ctx.stroke();
            }
            
            const prices = data.flat().filter((_, i) => [1, 2, 3, 4].includes(i % 5)).map(Number);
            const minPrice = Math.min(...prices);
            const maxPrice = Math.max(...prices);
            const priceRange = maxPrice - minPrice || 1;
            
            const candleWidth = (width - padding * 2) / data.length;
            const gap = candleWidth * 0.2;
            
            data.forEach((item, index) => {
                const x = padding + index * candleWidth + gap / 2;
                const w = candleWidth - gap;
                
                const open = parseFloat(item[1]);
                const close = parseFloat(item[2]);
                const low = parseFloat(item[3]);
                const high = parseFloat(item[4]);
                
                const yOpen = padding + (height - padding * 2) * (1 - (open - minPrice) / priceRange);
                const yClose = padding + (height - padding * 2) * (1 - (close - minPrice) / priceRange);
                const yLow = padding + (height - padding * 2) * (1 - (low - minPrice) / priceRange);
                const yHigh = padding + (height - padding * 2) * (1 - (high - minPrice) / priceRange);
                
                const isGreen = close >= open;
                ctx.fillStyle = isGreen ? '#22c55e' : '#ef4444';
                ctx.strokeStyle = isGreen ? '#22c55e' : '#ef4444';
                ctx.lineWidth = 1;
                
                ctx.beginPath();
                ctx.moveTo(x + w / 2, yLow);
                ctx.lineTo(x + w / 2, yHigh);
                ctx.stroke();
                
                const bodyTop = Math.min(yOpen, yClose);
                const bodyHeight = Math.abs(yClose - yOpen) || 2;
                
                ctx.fillRect(x, bodyTop, w, bodyHeight);
                
                if (index % Math.ceil(data.length / 10) === 0) {
                    ctx.fillStyle = textColor;
                    ctx.font = '10px Arial';
                    ctx.fillText(item[0].slice(5), x, height - 10);
                }
            });
            
            ctx.fillStyle = textColor;
            ctx.font = '10px Arial';
            for (let i = 0; i <= 5; i++) {
                const price = maxPrice - (priceRange * i / 5);
                const y = padding + (height - padding * 2) * i / 5;
                ctx.fillText(price.toFixed(1), 5, y + 4);
            }
        }

        async function handleSearch() {
            const input = document.getElementById('stock-code');
            const code = formatCode(input.value);
            
            if (!code) {
                alert('请输入有效的股票代码');
                return;
            }
            
            const status = document.getElementById('status');
            status.textContent = `正在获取 ${code} 的数据...`;
            
            let data = await fetchData(code);
            
            if (!data) {
                data = generateMockData();
                status.textContent = `${code} - 获取真实数据失败，显示模拟数据`;
            } else {
                status.textContent = `${code} - 显示实时数据 (${data.length}条)`;
            }
            
            const last = data[data.length - 1];
            document.getElementById('open-price').textContent = `¥${last[1]}`;
            document.getElementById('close-price').textContent = `¥${last[2]}`;
            document.getElementById('high-price').textContent = `¥${last[4]}`;
            document.getElementById('low-price').textContent = `¥${last[3]}`;
            
            renderChart(data);
        }

        document.addEventListener('DOMContentLoaded', () => {
            renderChart(serverData);
            
            const btn = document.getElementById('search-btn');
            const input = document.getElementById('stock-code');
            
            btn.addEventListener('click', handleSearch);
            
            input.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') handleSearch();
            });
        });
    </script>
</MainGridLayout>